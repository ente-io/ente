NEXT_TELEMETRY_DISABLED = 1

# For details on how Next.js loads environment files in this repo, see
# `apps/photos/.env`.
#
# The albums app supports the same endpoint-related variables as the photos
# app:
#
# - `NEXT_PUBLIC_ENTE_ENDPOINT` for the API origin.
# - `NEXT_PUBLIC_ENTE_ALBUMS_ENDPOINT` for the externally visible albums origin.
# - `NEXT_PUBLIC_ENTE_PHOTOS_ENDPOINT` for the photos app origin used when
#   handing off join/login flows.
#
# Example:
#
# NEXT_PUBLIC_ENTE_ENDPOINT = http://localhost:8080
# NEXT_PUBLIC_ENTE_ALBUMS_ENDPOINT = http://localhost:3002
# NEXT_PUBLIC_ENTE_PHOTOS_ENDPOINT = http://localhost:3000
#
# Set this only when building Ente's official production albums deployment.
#
# NEXT_PUBLIC_ENTE_OFFICIAL_ALBUMS_APP = 1
