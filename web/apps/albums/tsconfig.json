{
    "compilerOptions": {
        "noEmit": true,
        "lib": ["ESnext", "DOM", "DOM.Iterable", "WebWorker"],
        "target": "ES2020",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "jsx": "preserve",
        "isolatedModules": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "verbatimModuleSyntax": true,
        "resolveJsonModule": true,
        "strict": true,
        "noImplicitReturns": true,
        "noUnusedParameters": true,
        "noUnusedLocals": true,
        "noFallthroughCasesInSwitch": true,
        "noUncheckedIndexedAccess": true,
        "exactOptionalPropertyTypes": false,
        "allowJs": true,
        "incremental": true,
        "baseUrl": ".",
        "paths": {
            "components/*": ["vendor/photos/components/*"],
            "hooks/*": ["vendor/photos/hooks/*"],
            "services/*": ["vendor/photos/services/*"],
            "utils/*": ["vendor/photos/utils/*"],
            "styles/*": ["vendor/photos/styles/*"],
            "ente-base/*": ["vendor/ente-base/*"],
            "ente-gallery/*": ["vendor/ente-gallery/*"],
            "ente-media/*": ["vendor/ente-media/*"],
            "ente-new/*": ["vendor/ente-new/*"],
            "ente-utils/*": ["vendor/ente-utils/*"]
        }
    },
    "include": [
        "next-env.d.ts",
        "src/**/*.ts",
        "src/**/*.tsx",
        "src/**/*.js",
        "vendor/**/*.ts",
        "vendor/**/*.tsx",
        "vendor/**/*.js",
        "vendor/**/*.d.ts"
    ],
    "exclude": ["node_modules", "out", ".next", ".next-desktop"]
}
