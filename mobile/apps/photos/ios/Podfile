source 'https://github.com/ente-io/ffmpeg-kit-custom-repo-ios.git'
platform :ios, '14.0'

source 'https://cdn.cocoapods.org/'

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Generated.xcconfig, then run flutter pub get"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

target 'Runner' do
  use_frameworks!
  use_modular_headers!

  # Local pod wrapper for rust/uniffi/core. Sources/XCFramework are generated
  # during pod install via CoreUniFFI.podspec prepare_command.
  pod 'CoreUniFFI', :path => './CoreUniFFI'
  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
end

target 'ShareExtension' do
  use_frameworks!
  use_modular_headers!
  # Keep ShareExtension pod graph empty; it uses a local fallback implementation
  # when receive_sharing_intent is not present.
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
    target.build_configurations.each do |config|
      config.build_settings.delete 'IPHONEOS_DEPLOYMENT_TARGET'
      config.build_settings['EXCLUDED_ARCHS[sdk=iphonesimulator*]'] = 'arm64'
    end

  end

  installer.aggregate_targets.each do |aggregate_target|
    aggregate_target.user_project.native_targets.each do |target|
      target.build_configurations.each do |config|
        config.build_settings['EXCLUDED_ARCHS[sdk=iphonesimulator*]'] = 'arm64'
      end
    end
    aggregate_target.user_project.save
  end
end

post_integrate do |_installer|
  # ShareExtension intentionally has no pods linked directly. CocoaPods can
  # still add Pods_ShareExtension.framework references, which then fail to
  # resolve at link time. Remove those stale references after integration.
  begin
    user_project_path = File.join(__dir__, 'Runner.xcodeproj')
    user_project = Xcodeproj::Project.open(user_project_path)
    share_target = user_project.targets.find { |target| target.name == 'ShareExtension' }

    if share_target
      share_target.frameworks_build_phase.files
        .select { |build_file| build_file.file_ref&.path == 'Pods_ShareExtension.framework' }
        .each { |build_file| share_target.frameworks_build_phase.remove_build_file(build_file) }
    end

    user_project.files
      .select { |file_ref| file_ref.path == 'Pods_ShareExtension.framework' }
      .each(&:remove_from_project)

    user_project.save
  rescue => error
    Pod::UI.warn("Failed to cleanup stale ShareExtension pod framework refs: #{error}")
  end
end
