{
    "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
    "productName": "Ensu",
    "version": "0.1.17-beta",
    "identifier": "io.ente.ensu",
    "mainBinaryName": "Ensu",
    "build": {
        "beforeDevCommand": "node ../../../web/scripts/check-deps.mjs && cd ../../../web && npm run build:wasm && npm exec --workspace ensu -- next dev -p 3010",
        "beforeBuildCommand": "node scripts/tauri-build-web.mjs",
        "devUrl": "http://localhost:3010",
        "frontendDist": "../../../../web/apps/ensu/out"
    },
    "app": {
        "windows": [
            {
                "title": "Ensu",
                "width": 1200,
                "height": 800,
                "minWidth": 960,
                "minHeight": 640,
                "resizable": true,
                "visible": false,
                "hiddenTitle": false
            }
        ],
        "security": { "csp": null }
    },
    "bundle": {
        "active": true,
        "targets": "all",
        "icon": ["icons/icon.icns", "icons/icon.ico", "icons/icon.png"],
        "macOS": { "minimumSystemVersion": "10.15" }
    },
    "plugins": {
        "updater": {
            "endpoints": ["https://ente.com/release-info/ensu-desktop.json"],
            "pubkey": ""
        }
    }
}
