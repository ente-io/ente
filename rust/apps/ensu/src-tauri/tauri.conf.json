{
  "productName": "Ensu",
  "version": "0.1.9",
  "identifier": "io.ente.ensu",
  "mainBinaryName": "Ensu",
  "build": {
    "beforeDevCommand": "cd ../../../web && yarn build:wasm && yarn workspace ensu next dev -p 3010",
    "beforeBuildCommand": "node scripts/tauri-build-web.mjs",
    "devUrl": "http://localhost:3010",
    "frontendDist": "../../../../web/apps/ensu/out"
  },
  "app": {
    "windows": [
      {
        "title": "Ensu",
        "width": 1200,
        "height": 800,
        "minWidth": 960,
        "minHeight": 640,
        "resizable": true,
        "visible": false,
        "hiddenTitle": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "shell": {
      "open": "^((mailto:)|(tel:)|(https?://)|(file://)).+"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.icns", "icons/icon.ico", "icons/icon.png"]
  }
}
