{
    "$schema": "../gen/schemas/desktop-schema.json",
    "identifier": "main-capability",
    "description": "Capability for the main Ensu desktop window",
    "windows": ["main"],
    "permissions": [
        "core:default",
        "dialog:default",
        "fs:allow-exists",
        "fs:allow-mkdir",
        "fs:allow-open",
        "fs:allow-read",
        "fs:allow-read-file",
        "fs:allow-remove",
        "fs:allow-stat",
        "fs:allow-write-file",
        "opener:allow-default-urls",
        "opener:allow-open-url",
        "process:allow-restart",
        "updater:default",
        {
            "identifier": "fs:scope",
            "allow": [
                { "path": "$APPDATA" },
                { "path": "$APPDATA/*" },
                { "path": "$APPDATA/**" },
                { "path": "$DOCUMENT" },
                { "path": "$DOCUMENT/*" },
                { "path": "$DOCUMENT/**" }
            ]
        },
        {
            "identifier": "opener:allow-open-path",
            "allow": [
                { "path": "$APPDATA/ensu_llmchat_attachments_v2/*" },
                { "path": "$APPDATA/ensu_llmchat_attachments_v2/**" }
            ]
        }
    ]
}
