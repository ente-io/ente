{
    "name": "ente",
    "version": "1.7.25-beta",
    "private": true,
    "description": "Desktop client for Ente Photos",
    "repository": "github:ente-io/photos-desktop",
    "author": "Ente <code@ente.com>",
    "main": "app/main.js",
    "scripts": {
        "build": "npm run build-renderer && npm run build-main",
        "build-main": "tsc && electron-builder",
        "build-main:quick": "tsc && electron-builder --dir --config.compression=store --config.mac.identity=null",
        "build-renderer": "npm run check-web-deps && cross-env-shell _ENTE_IS_DESKTOP=1 \"cd ../web && npm run build:photos && cd ../desktop && shx rm -rf out && shx cp -r ../web/apps/photos/out out\"",
        "build-renderer:ci": "cross-env-shell _ENTE_IS_DESKTOP=1 \"cd ../web && npm ci && npm run build:photos && cd ../desktop && shx rm -rf out && shx cp -r ../web/apps/photos/out out\"",
        "build:ci": "npm run build-renderer:ci && tsc",
        "build:quick": "npm run build-renderer && npm run build-main:quick",
        "check-web-deps": "node ../web/scripts/check-deps.mjs",
        "dev": "concurrently --kill-others --success first --names 'main,rndr' \"npm run dev-main\" \"npm run dev-renderer\"",
        "dev-main": "tsc && electron .",
        "dev-renderer": "npm run check-web-deps && cross-env-shell _ENTE_IS_DESKTOP=1 \"cd ../web && npm exec --workspace photos -- next dev -p 3008\"",
        "postinstall": "electron-builder install-app-deps",
        "lint": "prettier --check --log-level warn . && eslint && tsc",
        "lint:fix": "prettier --write --log-level warn . && eslint && tsc",
        "prepare": "node scripts/vips.js"
    },
    "overrides": {
        "yauzl": "^3.3.1"
    },
    "dependencies": {
        "any-shell-escape": "0.1.1",
        "auto-launch": "5.0.6",
        "chokidar": "4.0.3",
        "clip-bpe-js": "0.0.6",
        "comlink": "4.4.2",
        "compare-versions": "6.1.1",
        "electron-log": "5.4.3",
        "electron-store": "11.0.2",
        "electron-updater": "6.6.5",
        "ffmpeg-static": "5.2.0",
        "lru-cache": "11.2.2",
        "next-electron-server": "1.0.0",
        "node-stream-zip": "1.15.0",
        "onnxruntime-node": "1.22.0-rev",
        "zod": "4.1.12"
    },
    "devDependencies": {
        "@eslint/js": "9.30.1",
        "@types/auto-launch": "5.0.5",
        "@types/node": "24.12.0",
        "ajv": "8.17.1",
        "concurrently": "9.2.1",
        "cross-env": "10.1.0",
        "electron": "41.2.0",
        "electron-builder": "26.0.14",
        "eslint": "9.9.1",
        "prettier": "3.6.2",
        "prettier-plugin-organize-imports": "4.3.0",
        "prettier-plugin-packagejson": "2.5.19",
        "shx": "0.4.0",
        "typescript": "5.8.3",
        "typescript-eslint": "8.35.1"
    },
    "packageManager": "npm@11.12.1",
    "productName": "ente"
}
